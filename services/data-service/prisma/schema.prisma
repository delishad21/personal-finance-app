generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Auth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// User and Profile
model User {
  id            String    @id @default(cuid())
  username      String    @unique
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  password      String?
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts           Account[]
  sessions           Session[]
  settings           UserSettings?
  categories         Category[]
  accountIdentifiers AccountIdentifier[]
  transactions       Transaction[]
  importBatches      ImportBatch[]
  trips              Trip[]
  importRules        ImportRule[]

  @@map("users")
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id")
  theme            String   @default("light") // light or dark
  currency         String   @default("SGD")
  autoLabelEnabled Boolean  @default(false) @map("auto_label_enabled")
  autoLabelThreshold Decimal @default(0.5) @map("auto_label_threshold") @db.Decimal(4, 2)
  paylahInternalPrompted Boolean @default(false) @map("paylah_internal_prompted")
  paylahAutoInternal Boolean @default(false) @map("paylah_auto_internal")
  dateFormat       String   @default("MM/dd/yyyy")
  defaultTimeframe String   @default("month") @map("default_timeframe")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// Account Numbers
model AccountIdentifier {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  accountIdentifier String   @map("account_number")
  color             String   @default("#6366f1") // hex color
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, accountIdentifier])
  @@map("account_numbers")
}

// Categories
model Category {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  color     String   @default("#1976d2") // hex color
  icon      String   @default("category")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  tripEntries  TripEntry[]

  @@unique([userId, name])
  @@map("categories")
}

// Import Batches
model ImportBatch {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  filename    String
  fileType    String      @map("file_type") // pdf, csv
  parserId    String      @map("parser_id")
  status      BatchStatus @default(PENDING)
  uploadedAt  DateTime    @default(now()) @map("uploaded_at")
  committedAt DateTime?   @map("committed_at")
  expiresAt   DateTime    @map("expires_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("import_batches")
}

enum BatchStatus {
  PENDING
  COMMITTED
  CANCELLED
}

// Transactions
model Transaction {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  date              DateTime
  description       String   @db.Text
  label             String?  @db.Text // User-editable label
  categoryId        String?  @map("category_id")
  amountIn          Decimal? @map("amount_in") @db.Decimal(12, 2)
  amountOut         Decimal? @map("amount_out") @db.Decimal(12, 2)
  balance           Decimal? @db.Decimal(12, 2)
  accountIdentifier String?  @map("account_number") // Account identifier from statement
  source            String? // bank name or source
  currency          String   @default("SGD")
  metadata          Json? // extra fields from parsing
  linkage           Json? // Transaction linkage data for internal/reimbursement
  importBatchId     String?  @map("import_batch_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  importBatch  ImportBatch?  @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  tripFundings TripFunding[]
  tripEntries  TripEntry[]   @relation("TripEntrySourceTransaction")

  @@index([userId, date])
  @@index([userId, categoryId])
  @@map("transactions")
}

// Trips
model Trip {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  name          String
  coverImageUrl String?   @map("cover_image_url")
  baseCurrency  String    @default("SGD") @map("base_currency")
  startDate     DateTime  @map("start_date")
  endDate       DateTime? @map("end_date")
  status        String    @default("active")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallets     Wallet[]
  fundings    TripFunding[]
  entries     TripEntry[]
  reimbursementAllocations TripReimbursementAllocation[]

  @@index([userId, startDate])
  @@map("trips")
}

model Wallet {
  id        String   @id @default(cuid())
  tripId    String   @map("trip_id")
  name      String
  currency  String
  color     String   @default("#60a5fa")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trip     Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fundings TripFunding[]
  entries  TripEntry[]

  @@unique([tripId, name, currency])
  @@map("wallets")
}

model TripFunding {
  id                  String   @id @default(cuid())
  tripId              String   @map("trip_id")
  walletId            String?  @map("wallet_id")
  entryId             String?  @unique @map("entry_id")
  bankTransactionId   String?  @map("bank_transaction_id")
  sourceType          String   @default("manual") @map("source_type")
  sourceCurrency      String   @map("source_currency")
  sourceAmount        Decimal  @map("source_amount") @db.Decimal(14, 4)
  destinationCurrency String   @map("destination_currency")
  destinationAmount   Decimal  @map("destination_amount") @db.Decimal(14, 4)
  fxRate              Decimal? @map("fx_rate") @db.Decimal(14, 6)
  baseAmount          Decimal? @map("base_amount") @db.Decimal(14, 4)
  feeAmount           Decimal? @map("fee_amount") @db.Decimal(14, 4)
  feeCurrency         String?  @map("fee_currency")
  metadata            Json?
  createdAt           DateTime @default(now()) @map("created_at")

  trip            Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  wallet          Wallet?      @relation(fields: [walletId], references: [id], onDelete: SetNull)
  entry           TripEntry?   @relation("TripFundingEntry", fields: [entryId], references: [id], onDelete: SetNull)
  bankTransaction Transaction? @relation(fields: [bankTransactionId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([bankTransactionId])
  @@map("trip_fundings")
}

model TripEntry {
  id                  String   @id @default(cuid())
  tripId              String   @map("trip_id")
  walletId            String?  @map("wallet_id")
  sourceType          String   @default("wallet") @map("source_type")
  sourceTransactionId String?  @map("source_transaction_id")
  type                String
  transactionDate     DateTime @map("transaction_date")
  description         String   @db.Text
  label               String?
  localCurrency       String   @map("local_currency")
  localAmount         Decimal  @map("local_amount") @db.Decimal(14, 4)
  fxRate              Decimal  @map("fx_rate") @db.Decimal(14, 6)
  baseAmount          Decimal  @map("base_amount") @db.Decimal(14, 4)
  feeAmount           Decimal? @map("fee_amount") @db.Decimal(14, 4)
  feeCurrency         String?  @map("fee_currency")
  categoryId          String?  @map("category_id")
  linkedEntryId       String?  @map("linked_entry_id")
  metadata            Json?
  createdAt           DateTime @default(now()) @map("created_at")

  trip              Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  wallet            Wallet?      @relation(fields: [walletId], references: [id], onDelete: SetNull)
  sourceTransaction Transaction? @relation("TripEntrySourceTransaction", fields: [sourceTransactionId], references: [id], onDelete: SetNull)
  category          Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  linkedEntry       TripEntry?   @relation("TripEntryLink", fields: [linkedEntryId], references: [id], onDelete: SetNull)
  linkedFrom        TripEntry[]  @relation("TripEntryLink")
  fundingRecord     TripFunding? @relation("TripFundingEntry")
  reimbursementAllocationsAsSource TripReimbursementAllocation[] @relation("TripReimbursementSource")
  reimbursementAllocationsAsTarget TripReimbursementAllocation[] @relation("TripReimbursementTarget")

  @@index([tripId])
  @@index([tripId, type])
  @@index([linkedEntryId])
  @@index([sourceType])
  @@index([sourceTransactionId])
  @@map("trip_entries")
}

model TripReimbursementAllocation {
  id                    String   @id @default(cuid())
  tripId                String   @map("trip_id")
  reimbursementEntryId  String   @map("reimbursement_entry_id")
  reimbursedEntryId     String   @map("reimbursed_entry_id")
  amountBase            Decimal  @map("amount_base") @db.Decimal(14, 4)
  reimbursingLocalAmount Decimal @map("reimbursing_local_amount") @db.Decimal(14, 4)
  reimbursedLocalAmount  Decimal @map("reimbursed_local_amount") @db.Decimal(14, 4)
  reimbursingFxRate     Decimal  @map("reimbursing_fx_rate") @db.Decimal(14, 6)
  reimbursedFxRate      Decimal  @map("reimbursed_fx_rate") @db.Decimal(14, 6)
  createdAt             DateTime @default(now()) @map("created_at")

  trip                 Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  reimbursementEntry   TripEntry @relation("TripReimbursementSource", fields: [reimbursementEntryId], references: [id], onDelete: Cascade)
  reimbursedEntry      TripEntry @relation("TripReimbursementTarget", fields: [reimbursedEntryId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([reimbursementEntryId])
  @@index([reimbursedEntryId])
  @@unique([reimbursementEntryId, reimbursedEntryId])
  @@map("trip_reimbursement_allocations")
}

// Parser Definitions
model ParserDefinition {
  id          String   @id // e.g., "chase_bank_csv"
  name        String // "Chase Bank CSV"
  description String?  @db.Text
  fileType    String   @map("file_type") // csv, pdf
  config      Json // parser configuration
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("parser_definitions")
}

model ImportRule {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  name            String
  parserId        String?  @map("parser_id")
  matchType       String   @default("description_contains") @map("match_type")
  matchValue      String?  @map("match_value")
  caseSensitive   Boolean  @default(false) @map("case_sensitive")
  enabled         Boolean  @default(true)
  setLabel        String?  @map("set_label")
  setCategoryName String?  @map("set_category_name")
  markInternal    Boolean  @default(false) @map("mark_internal")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled, parserId])
  @@index([userId, sortOrder, createdAt])
  @@unique([userId, name])
  @@map("import_rules")
}
